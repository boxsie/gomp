<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Until the Ensemble.Client SDK bump (FromEnv + spawn-token) is published
         to nuget.org, gomp consumes it from this local feed. `dotnet pack` the
         SDK from the ensemble checkout into ./local-packages to refresh it.
         Remove this source once the bump is on nuget.org. -->
    <add key="local" value="local-packages" />
  </packageSources>
</configuration>
