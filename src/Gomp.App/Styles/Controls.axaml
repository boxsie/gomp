<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================= Typography defaults ================= -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.wordmark">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="LetterSpacing" Value="-1.0" />
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="20" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
    </Style>
    <Style Selector="TextBlock.faint">
        <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.label">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LetterSpacing" Value="0.8" />
    </Style>
    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ================= Buttons ================= -->
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.13" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Primary: the purple pill -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Padding" Value="20,10" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentBright}" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentDeep}" />
    </Style>

    <!-- Ghost: subtle elevated chip -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="{StaticResource BgElevated}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BgHover}" />
    </Style>

    <!-- Danger ghost: the bar / leave action -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Danger}" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A1412" />
    </Style>

    <!-- Round icon button (the + actions) -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="{StaticResource BgElevated}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentSoft}" />
    </Style>

    <!-- Quiet link button -->
    <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.link:pointerover">
        <Setter Property="Foreground" Value="{StaticResource AccentGlow}" />
    </Style>

    <!-- ================= Text input ================= -->
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="Background" Value="{StaticResource BgInput}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentGlow}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
        <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource HairlineSoft}" />
        <Setter Property="Background" Value="{StaticResource BgInput}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        <Setter Property="Background" Value="{StaticResource BgInput}" />
    </Style>

    <!-- ================= Cards & chips ================= -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource BgSurface}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.chip">
        <Setter Property="Background" Value="{StaticResource BgElevated}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Padding" Value="9,3" />
    </Style>

    <Style Selector="Border.accentChip">
        <Setter Property="Background" Value="{StaticResource AccentSoft}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Padding" Value="9,3" />
    </Style>

    <!-- ================= Chat / member rows ================= -->
    <Style Selector="Border.msgRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.msgRow:pointerover">
        <Setter Property="Background" Value="{StaticResource BgSurface}" />
    </Style>

    <!-- ================= Presence dot ================= -->
    <Style Selector="Ellipse.dot">
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="Fill" Value="{StaticResource TextFaint}" />
    </Style>
    <Style Selector="Ellipse.dot.online">
        <Setter Property="Fill" Value="{StaticResource Online}" />
    </Style>

    <!-- ================= Pub list rows ================= -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <!-- Stretch the content so the whole row (not just the text) is the hover/hit
             target, otherwise only the content-width band reacts to the pointer. -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BgSurface}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BgElevated}" />
    </Style>

    <!-- ================= ComboBox ================= -->
    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="Background" Value="{StaticResource BgInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
        <Setter Property="Padding" Value="12,9" />
    </Style>

</Styles>
